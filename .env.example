# Database connection (mysql, postgres, etc)
DATABASE_TYPE="postgresql"
DATABASE_URL="postgresql://user:pass@localhost:5432/nest_db?schema=public"
# DATABASE_TYPE="mysql"
# DATABASE_HOST="localhost"
# DATABASE_PORT="3306"
# DATABASE_USER="user"
# DATABASE_PASSWORD="pass"
# DATABASE_NAME="nest_db"
# DATABASE_URL="mysql://user:pass@localhost:3306/nest_db"

# Default Port
PORT=3000

# Security
ALLOWED_ORIGINS=http://localhost:5173

# JWT
JWT_SECRET="my-nest-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Rate Limit (requests x seconds)
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_SECONDS=60

# Misc
BCRYPT_SALT_ROUNDS=10
DATABASE_CONNECTION_LIMIT=5
